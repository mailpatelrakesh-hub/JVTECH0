rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate IDs to prevent resource poisoning
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Candidates collection rules
    match /candidates/{candidateId} {
      allow read, write: if isValidId(candidateId);
    }

    // Settings collection rules
    match /settings/{settingsId} {
      allow read, write: if isValidId(settingsId);
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if isValidId(userId);
    }

    // Interviews collection rules
    match /interviews/{interviewId} {
      allow read, write: if isValidId(interviewId);
    }
  }
}
